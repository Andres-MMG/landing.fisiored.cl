---
/**
 * Appointment modal — interstitial that opens Flowcitas in a popup window.
 *
 * Why a popup instead of an iframe:
 * flowcitas authenticates against Supabase with session cookies scoped
 * to the flowcitas.com domain. Browsers do NOT forward third-party
 * cookies (SameSite=Lax default) into cross-origin iframe contexts, so
 * the embedded version returned 401 Unauthorized from Supabase while
 * the top-level version worked fine.
 *
 * Opening flowcitas as a top-level popup window (window.open) makes it
 * same-site to itself, so cookies flow normally. On mobile devices
 * where popup windows are not supported, we fall back to _blank.
 */

const FLOWCITAS_URL = 'https://app.flowcitas.com/booking/fisiored';
---

<div
  id="appointment-modal"
  data-appointment-modal
  role="dialog"
  aria-modal="true"
  aria-labelledby="appointment-modal-title"
  aria-hidden="true"
  class="hidden fixed inset-0 z-[60] flex items-center justify-center p-4 sm:p-6"
>
  <!-- Overlay -->
  <button
    type="button"
    data-close-appointment
    aria-label="Cerrar"
    class="absolute inset-0 bg-on-surface/60 backdrop-blur-sm cursor-default"
  ></button>

  <!-- Panel -->
  <div
    data-appointment-panel
    role="document"
    tabindex="-1"
    class="relative w-full max-w-lg bg-white rounded-3xl overflow-hidden shadow-2xl flex flex-col focus:outline-none"
  >
    <header class="flex items-start justify-between gap-4 px-6 pt-6 pb-2">
      <div class="flex items-start gap-3">
        <div class="w-12 h-12 rounded-2xl bg-primary-fixed text-primary flex items-center justify-center flex-shrink-0">
          <span class="material-symbols-outlined text-3xl">event_available</span>
        </div>
        <div>
          <h2 id="appointment-modal-title" class="font-headline text-headline-sm text-on-surface leading-tight">
            Reservar hora en FisioRed
          </h2>
          <p class="font-label-md text-label-md text-on-surface-variant mt-1">Sistema de reservas online</p>
        </div>
      </div>
      <button
        type="button"
        data-close-appointment
        aria-label="Cerrar"
        class="w-10 h-10 rounded-full bg-surface-container-low hover:bg-surface-container text-on-surface flex items-center justify-center transition-colors flex-shrink-0"
      >
        <span class="material-symbols-outlined text-[20px]">close</span>
      </button>
    </header>

    <div class="px-6 py-4 space-y-4">
      <p class="font-body text-body-md text-on-surface-variant">
        Te vamos a abrir el sistema de reservas en una ventana segura. Si tu navegador bloquea la ventana, podés usar el enlace directo.
      </p>

      <div class="flex flex-col sm:flex-row gap-3">
        <button
          type="button"
          data-open-flowcitas
          class="flex-1 bg-primary text-on-primary font-headline text-headline-sm px-6 py-4 rounded-2xl hover:bg-primary-container btn-tap transition-all shadow-md flex items-center justify-center gap-2"
        >
          <span class="material-symbols-outlined">open_in_new</span>
          Continuar
        </button>
        <a
          href={FLOWCITAS_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="flex-1 border-2 border-primary text-primary font-headline text-headline-sm px-6 py-4 rounded-2xl hover:bg-primary hover:text-white btn-tap transition-all flex items-center justify-center gap-2"
        >
          <span class="material-symbols-outlined">tab</span>
          Nueva pestaña
        </a>
      </div>

      <div class="flex items-center gap-3 text-on-surface-variant">
        <span class="material-symbols-outlined text-[20px] text-primary">verified_user</span>
        <p class="font-label-md text-label-md">Conexión segura · Sincronización en tiempo real · Confirmación inmediata</p>
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    const FLOWCITAS_URL = 'https://app.flowcitas.com/booking/fisiored';
    const POPUP_FEATURES = 'width=520,height=760,scrollbars=yes,resizable=yes';

    const modal = document.getElementById('appointment-modal');
    const panel = modal?.querySelector<HTMLElement>('[data-appointment-panel]');
    const body = document.body;

    if (!modal || !panel) return;

    let lastFocused: HTMLElement | null = null;

    function isMobile(): boolean {
      return window.matchMedia('(max-width: 768px)').matches;
    }

    /**
     * Open Flowcitas in a top-level popup window (520x760). On mobile
     * browsers fall back to a new tab. Pass a specific URL to deep-link
     * a professional (?professional=ID); otherwise the generic
     * booking page is opened.
     */
    function openFlowcitas(url: string = FLOWCITAS_URL) {
      const features = isMobile() ? '_blank' : `flowcitas,${POPUP_FEATURES}`;
      const win = window.open(url, features);
      if (!win && !isMobile()) {
        console.info('[appointment] popup blocked; user can use the fallback link');
      }
    }

    function openModal() {
      lastFocused = document.activeElement as HTMLElement | null;
      modal!.classList.remove('hidden');
      modal!.setAttribute('aria-hidden', 'false');
      body.style.overflow = 'hidden';
      setTimeout(() => panel!.focus(), 50);
    }

    function closeModal() {
      modal!.classList.add('hidden');
      modal!.setAttribute('aria-hidden', 'true');
      body.style.overflow = '';
      lastFocused?.focus();
    }

    // Triggers
    document.querySelectorAll<HTMLElement>('[data-open-appointment]').forEach((btn) => {
      btn.addEventListener('click', openModal);
    });

    // Per-professional booking buttons inside Team cards.
    // Each button carries its URL in data-url; we open the popup directly
    // without showing the interstitial modal (faster path).
    document.querySelectorAll<HTMLElement>('[data-team-booking]').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const url = btn.dataset.url || FLOWCITAS_URL;
        openFlowcitas(url);
      });
    });

    // Primary action inside the modal: open popup and close modal
    document.querySelectorAll<HTMLElement>('[data-open-flowcitas]').forEach((btn) => {
      btn.addEventListener('click', () => {
        openFlowcitas();
        closeModal();
      });
    });

    // Close handlers
    document.querySelectorAll<HTMLElement>('[data-close-appointment]').forEach((btn) => {
      btn.addEventListener('click', closeModal);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal!.classList.contains('hidden')) {
        closeModal();
      }
    });

    // Focus trap
    const focusableSelector =
      'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])';
    panel.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key !== 'Tab') return;
      const focusable = Array.from(
        modal!.querySelectorAll<HTMLElement>(focusableSelector)
      ).filter((el) => !el.hasAttribute('disabled'));
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        last.focus();
        e.preventDefault();
      } else if (!e.shiftKey && document.activeElement === last) {
        first.focus();
        e.preventDefault();
      }
    });
  })();
</script>
