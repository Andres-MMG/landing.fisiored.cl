---
import { clinic } from '../data/clinic';
import { team } from '../data/team';

const heroFallback =
  'https://images.unsplash.com/photo-1576091160550-2173dba999ef?auto=format&fit=crop&w=900&q=80';
const specialistCount = team.length;
---

---

<section id="inicio" class="relative min-h-[760px] md:min-h-[820px] flex items-center overflow-hidden bg-surface">
  <div class="absolute top-20 right-0 w-1/3 h-full dot-pattern opacity-20 pointer-events-none" aria-hidden="true"></div>
  <div
    class="absolute -bottom-20 -left-20 w-64 h-64 bg-primary-fixed opacity-10 rounded-full blur-3xl blob pointer-events-none"
    aria-hidden="true"
  >
  </div>

  <div class="px-4 md:px-margin-desktop w-full max-w-container-max mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center relative z-10 py-16 md:py-24">
    <div class="space-y-8 section-fade">
      <div class="inline-flex items-center gap-2 bg-primary-fixed/40 text-primary px-4 py-2 rounded-full font-label-md text-label-md">
        <span class="material-symbols-outlined text-[18px]">verified</span>
        Centro fundado en {clinic.established} · Convenio Fonasa
      </div>

      <h1 class="font-headline text-headline-xl text-on-surface max-w-xl">
        Centro médico y de rehabilitación en <span class="text-primary">Nueva Imperial</span>
      </h1>

      <p class="font-body text-body-lg text-on-surface-variant max-w-lg leading-relaxed">
        8 especialidades — kinesiología, pediatría, terapia ocupacional, fonoaudiología, nutrición, psicología, osteopatía y masoterapia — atendidas por un equipo interdisciplinario con atención personalizada para niños, adolescentes y adultos. Convenio Fonasa.
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#contacto" class="bg-primary text-on-primary px-8 py-4 rounded-xl font-headline text-headline-sm hover:shadow-lg btn-tap transition-all flex items-center justify-center gap-3">
          <span class="material-symbols-outlined">calendar_today</span>
          Agendar Hora
        </a>
        <a href="#servicios" class="bg-tertiary-fixed text-on-tertiary-fixed px-8 py-4 rounded-xl font-headline text-headline-sm hover:bg-tertiary-fixed-dim transition-all flex items-center justify-center gap-3">
          Ver Servicios
        </a>
      </div>

      <div class="flex items-center gap-6 pt-4">
        <div class="flex -space-x-3">
          <div class="w-10 h-10 rounded-full bg-primary-fixed border-2 border-surface flex items-center justify-center text-primary">
            <span class="material-symbols-outlined text-[18px]">person</span>
          </div>
          <div class="w-10 h-10 rounded-full bg-tertiary-fixed border-2 border-surface flex items-center justify-center text-tertiary">
            <span class="material-symbols-outlined text-[18px]">person</span>
          </div>
          <div class="w-10 h-10 rounded-full bg-secondary-container border-2 border-surface flex items-center justify-center text-on-secondary-container">
            <span class="material-symbols-outlined text-[18px]">person</span>
          </div>
        </div>
        <div>
          <div class="font-headline text-headline-sm text-on-surface">+5.000</div>
          <div class="font-label-md text-label-md text-on-surface-variant">pacientes atendidos · {specialistCount} especialistas</div>
        </div>
      </div>
    </div>

    <div class="relative section-fade">
      <div class="aspect-[4/5] rounded-[32px] overflow-hidden soft-shadow border-4 border-surface-container-lowest">
        <img
          class="w-full h-full object-cover"
          alt="Kinesiólogo profesional atendiendo a un paciente en un centro médico moderno con detalles en verde teal"
          src={heroFallback}
          loading="eager"
        />
      </div>

      <div class="absolute -bottom-6 -left-6 glass-card p-6 rounded-2xl soft-shadow border border-outline-variant max-w-[220px]">
        <div class="flex items-center gap-3 mb-2">
          <div class="w-10 h-10 bg-primary-container rounded-full flex items-center justify-center text-on-primary-container">
            <span class="material-symbols-outlined">groups</span>
          </div>
          <span class="font-headline text-headline-sm">+5k</span>
        </div>
        <p class="font-label-md text-label-md text-on-surface-variant">Pacientes atendidos con éxito</p>
      </div>

      <div class="absolute -top-4 -right-4 bg-primary text-on-primary px-4 py-2 rounded-full font-label-md text-label-md soft-shadow-sm hidden md:flex items-center gap-2">
        <span class="material-symbols-outlined text-[18px]">schedule</span>
        Atención hoy
      </div>
    </div>
  </div>
</section>
