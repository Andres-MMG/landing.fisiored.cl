---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { clinic } from '../data/clinic';
import { team } from '../data/team';
import type { TeamMember } from '../data/team';

const badgeColorClass: Record<TeamMember['badge']['color'], string> = {
  primary: 'bg-primary',
  tertiary: 'bg-tertiary',
  secondary: 'bg-secondary',
  'tertiary-container': 'bg-tertiary-container',
};

function isImageMetadata(value: TeamMember['image']): value is ImageMetadata {
  return typeof value !== 'string';
}

function objectPositionClass(position: string | undefined): string {
  if (!position) return 'object-top';
  // Arbitrary value: object-[<value>]
  return `object-[${position}]`;
}

const flowcitasBaseUrl = 'https://app.flowcitas.com/booking/fisiored';
const bookingUrlFor = (id: string | undefined) =>
  id ? `${flowcitasBaseUrl}?professional=${id}` : null;
const whatsappUrlFor = (name: string) =>
  `${clinic.whatsappUrl}?text=${encodeURIComponent(
    `Hola, quiero reservar una hora con ${name} en FisioRed.`
  )}`;
---

<section id="equipo" class="py-20 md:py-24 bg-surface-container-low relative overflow-hidden">
  <div class="absolute top-0 right-0 w-1/3 h-full dot-pattern opacity-10 pointer-events-none" aria-hidden="true"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-tertiary-fixed rounded-full blur-[120px] opacity-30 pointer-events-none" aria-hidden="true"></div>

  <div class="px-4 md:px-margin-desktop w-full max-w-container-max mx-auto relative section-fade">
    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 bg-secondary-container text-on-secondary-container px-4 py-1.5 rounded-full mb-4">
        <span class="material-symbols-outlined text-[18px]">groups</span>
        <span class="font-label-md text-label-md">EQUIPO PROFESIONAL</span>
      </div>
      <h2 class="font-headline text-headline-lg text-on-surface mb-6 max-w-3xl mx-auto">
        Especialistas dedicados a tu <span class="text-primary italic">bienestar integral</span>
      </h2>
      <p class="font-body text-body-lg text-on-surface-variant max-w-2xl mx-auto">
        Un equipo multidisciplinario de profesionales altamente calificados en medicina, rehabilitación y estimulación temprana.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-gutter">
      {
        team.map((member) =>
          member.featured ? (
            <article class="profile-hover flex flex-col lg:col-span-2 glass-card rounded-2xl overflow-hidden shadow-sm transition-all duration-300 hover:shadow-xl md:flex-row">
              <div class="md:w-1/2 h-64 md:h-auto overflow-hidden relative bg-surface-container-high zoom-on-hover">
                {isImageMetadata(member.image) ? (
                  <Image
                    src={member.image}
                    alt={member.imageAlt}
                    class={`profile-img w-full h-full object-cover ${objectPositionClass(member.featured ? undefined : member.imagePosition)}`}
                    widths={[400, 600, 900]}
                    sizes="(min-width: 1024px) 50vw, 100vw"
                    loading="lazy"
                  />
                ) : (
                  <img
                    src={member.image}
                    alt={member.imageAlt}
                    class={`profile-img w-full h-full object-cover ${objectPositionClass(member.featured ? undefined : member.imagePosition)}`}
                    loading="lazy"
                  />
                )}
                <div class="absolute top-4 left-4">
                  <span class={`${badgeColorClass[member.badge.color]} text-white px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider`}>
                    {member.badge.text}
                  </span>
                </div>
              </div>
              <div class="md:w-1/2 p-8 flex flex-col justify-center">
                <div class="mb-4 text-primary">
                  <span class="material-symbols-outlined text-5xl">child_care</span>
                </div>
                <h3 class="font-headline text-headline-md text-on-surface mb-2">{member.name}</h3>
                <p class="font-body text-body-lg text-on-surface-variant mb-6">{member.specialty}</p>
                <div class="space-y-3 mb-8">
                  {member.bullets?.map((bullet) => (
                    <div class="flex items-center gap-3 text-on-surface-variant">
                      <span class="material-symbols-outlined text-[20px] text-primary">check_circle</span>
                      <span class="font-label-md text-label-md">{bullet}</span>
                    </div>
                  ))}
                </div>
                <div class="flex flex-col sm:flex-row gap-3">
                  {bookingUrlFor(member.flowcitasId) && (
                    <button
                      type="button"
                      data-team-booking
                      data-url={bookingUrlFor(member.flowcitasId)}
                      class="bg-primary text-white py-3 px-5 rounded-full font-label-md text-label-md self-start hover:shadow-lg btn-tap transition-all flex items-center gap-2 whitespace-nowrap"
                    >
                      <span class="material-symbols-outlined text-[18px]">event_available</span>
                      Reservar cita
                    </button>
                  )}
                  <a
                    href={whatsappUrlFor(member.name)}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Contactar a ${member.name} por WhatsApp`}
                    class="border-2 border-whatsapp text-whatsapp p-3 rounded-full hover:bg-whatsapp hover:text-white btn-tap transition-all flex items-center justify-center"
                  >
                    <svg fill="currentColor" viewBox="0 0 24 24" width="20" height="20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448L.057 24zm6.597-3.51c1.595.948 3.555 1.46 5.535 1.463 5.344 0 9.692-4.347 9.694-9.693A9.616 9.616 0 0 0 14.96 6.195 9.61 9.61 0 0 0 6.105 7.4c-2.628 2.625-3.564 6.18-2.514 9.71l1.573-1.36c-.65-2.34.16-4.85 1.83-6.42a6.473 6.473 0 0 1 5.86-1.493c2.21.498 4.062 1.97 5.118 3.96.475.886.737 1.86.737 2.851 0 .84-.16 1.668-.49 2.46-.776 1.85-2.46 3.27-4.43 3.5-.86.106-1.71.018-2.5-.262l-.13-.04 1.59-4.65-.002-.006zm5.51-7.122c-.066-.112-.244-.18-.518-.31-.273-.13-1.617-.798-1.866-.89-.249-.092-.43-.137-.61.137-.18.273-.697.89-.854 1.074-.157.18-.314.205-.587.07-.273-.137-1.155-.426-2.2-1.358a8.276 8.276 0 0 1-1.527-1.69c-.16-.272-.017-.42.12-.55.124-.122.273-.318.41-.477.137-.158.182-.273.273-.453.092-.18.046-.336-.046-.466-.092-.13-.61-1.473-.836-2.02-.22-.53-.444-.46-.61-.468-.158-.008-.34-.01-.52-.01s-.48.07-.732.336c-.252.27-.96.94-.96 2.29 0 1.328.985 2.61 1.122 2.79.137.18 1.94 2.962 4.7 4.151.658.283 1.171.452 1.57.578.658.21 1.258.18 1.732.11.527-.08 1.617-.66 1.846-1.302.227-.64.227-1.19.16-1.302-.068-.112-.247-.18-.52-.318z"/>
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ) : (
            <article class="profile-hover flex flex-col glass-card rounded-2xl overflow-hidden shadow-sm transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
              <div class="h-64 overflow-hidden relative bg-surface-container-high zoom-on-hover">
                {isImageMetadata(member.image) ? (
                  <Image
                    src={member.image}
                    alt={member.imageAlt}
                    class={`profile-img w-full h-full object-cover ${objectPositionClass(member.imagePosition)}`}
                    widths={[300, 600]}
                    sizes="(min-width: 1024px) 25vw, 50vw"
                    loading="lazy"
                  />
                ) : (
                  <img
                    src={member.image}
                    alt={member.imageAlt}
                    class={`profile-img w-full h-full object-cover ${objectPositionClass(member.imagePosition)}`}
                    loading="lazy"
                  />
                )}
                <div class="absolute bottom-4 left-4">
                  <span class={`${badgeColorClass[member.badge.color]} text-white px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider`}>
                    {member.badge.text}
                  </span>
                </div>
              </div>
              <div class="p-6 flex flex-col flex-1">
                <h3 class="font-headline text-headline-sm text-on-surface mb-1">{member.name}</h3>
                <p class="font-body text-body-md text-on-surface-variant mb-4">{member.specialty}</p>
                <div class="mt-auto space-y-2">
                  {bookingUrlFor(member.flowcitasId) && (
                    <button
                      type="button"
                      data-team-booking
                      data-url={bookingUrlFor(member.flowcitasId)}
                      class="w-full bg-primary text-white py-2.5 rounded-lg font-label-md text-label-md hover:bg-primary-container btn-tap transition-all flex items-center justify-center gap-2"
                    >
                      <span class="material-symbols-outlined text-[18px]">event_available</span>
                      Reservar con {member.shortName ?? member.name}
                    </button>
                  )}
                  <a
                    href={whatsappUrlFor(member.name)}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-full border border-outline-variant text-on-surface-variant py-2 rounded-lg font-label-md text-label-md hover:border-whatsapp hover:text-whatsapp btn-tap transition-all flex items-center justify-center gap-2"
                    aria-label={`Reservar con ${member.name} por WhatsApp`}
                  >
                    <svg fill="currentColor" viewBox="0 0 24 24" width="16" height="16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448L.057 24zm6.597-3.51c1.595.948 3.555 1.46 5.535 1.463 5.344 0 9.692-4.347 9.694-9.693A9.616 9.616 0 0 0 14.96 6.195 9.61 9.61 0 0 0 6.105 7.4c-2.628 2.625-3.564 6.18-2.514 9.71l1.573-1.36c-.65-2.34.16-4.85 1.83-6.42a6.473 6.473 0 0 1 5.86-1.493c2.21.498 4.062 1.97 5.118 3.96.475.886.737 1.86.737 2.851 0 .84-.16 1.668-.49 2.46-.776 1.85-2.46 3.27-4.43 3.5-.86.106-1.71.018-2.5-.262l-.13-.04 1.59-4.65-.002-.006zm5.51-7.122c-.066-.112-.244-.18-.518-.31-.273-.13-1.617-.798-1.866-.89-.249-.092-.43-.137-.61.137-.18.273-.697.89-.854 1.074-.157.18-.314.205-.587.07-.273-.137-1.155-.426-2.2-1.358a8.276 8.276 0 0 1-1.527-1.69c-.16-.272-.017-.42.12-.55.124-.122.273-.318.41-.477.137-.158.182-.273.273-.453.092-.18.046-.336-.046-.466-.092-.13-.61-1.473-.836-2.02-.22-.53-.444-.46-.61-.468-.158-.008-.34-.01-.52-.01s-.48.07-.732.336c-.252.27-.96.94-.96 2.29 0 1.328.985 2.61 1.122 2.79.137.18 1.94 2.962 4.7 4.151.658.283 1.171.452 1.57.578.658.21 1.258.18 1.732.11.527-.08 1.617-.66 1.846-1.302.227-.64.227-1.19.16-1.302-.068-.112-.247-.18-.52-.318z"/>
                    </svg>
                    Reservar por WhatsApp
                  </a>
                </div>
              </div>
            </article>
          )
        )
      }
    </div>
  </div>
</section>
