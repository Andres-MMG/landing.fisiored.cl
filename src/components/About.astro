---
const gallery = [
  {
    src: 'https://images.unsplash.com/photo-1629909613654-28e377c37b09?auto=format&fit=crop&w=600&q=80',
    alt: 'Fachada moderna del centro médico FisioRed en Nueva Imperial',
    height: 'h-48',
  },
  {
    src: 'https://images.unsplash.com/photo-1631815589968-fdb09a223b1e?auto=format&fit=crop&w=600&q=80',
    alt: 'Sala de espera de la clínica, cómoda y tranquila',
    height: 'h-64',
  },
  {
    src: 'https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?auto=format&fit=crop&w=600&q=80',
    alt: 'Gimnasio de rehabilitación con equipamiento moderno',
    height: 'h-64',
  },
  {
    src: 'https://images.unsplash.com/photo-1551601651-2a8555f1a136?auto=format&fit=crop&w=600&q=80',
    alt: 'Equipo de profesionales de salud trabajando en conjunto',
    height: 'h-48',
  },
];

const highlights = [
  {
    title: 'Certificación Sanitaria',
    description: 'Cumplimos con todos los estándares ministeriales.',
  },
  {
    title: 'Compromiso Local',
    description: 'Arraigados profundamente en el bienestar de Nueva Imperial.',
  },
];
---

<section id="nosotros" class="py-20 md:py-24 bg-surface">
  <div class="px-4 md:px-margin-desktop w-full max-w-container-max mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center section-fade">
    <div class="order-2 lg:order-1 relative">
      <div class="grid grid-cols-2 gap-4">
        <div class="space-y-4">
          {
            gallery.slice(0, 2).map((img) => (
              <div class={`${img.height} rounded-2xl overflow-hidden shadow-md`}>
                <img src={img.src} alt={img.alt} class="w-full h-full object-cover" loading="lazy" />
              </div>
            ))
          }
        </div>
        <div class="pt-8 space-y-4">
          {
            gallery.slice(2, 4).map((img) => (
              <div class={`${img.height} rounded-2xl overflow-hidden shadow-md`}>
                <img src={img.src} alt={img.alt} class="w-full h-full object-cover" loading="lazy" />
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="order-1 lg:order-2 space-y-8">
      <span class="inline-block bg-secondary-container text-on-secondary-container px-4 py-1.5 rounded-full font-label-md text-label-md">Nuestra historia</span>
      <h2 class="font-headline text-headline-lg text-on-surface">Más que un centro médico, somos parte de tu comunidad</h2>
      <p class="font-body text-body-lg text-on-surface-variant leading-relaxed">
        FisioRed nace en Nueva Imperial con la misión de descentralizar la salud de alta calidad.
        Como el primer centro de estas características en la zona, somos un referente de confianza para cientos de familias.
      </p>
      <div class="space-y-4">
        {
          highlights.map((item) => (
            <div class="flex items-start gap-4">
              <div class="mt-1 text-primary">
                <span class="material-symbols-outlined">check_circle</span>
              </div>
              <div>
                <h4 class="font-label-md text-label-md text-on-surface font-bold">{item.title}</h4>
                <p class="font-body text-body-md text-on-surface-variant">{item.description}</p>
              </div>
            </div>
          ))
        }
      </div>
      <a href="#contacto" class="inline-flex items-center gap-2 text-primary font-label-md text-label-md font-bold hover:underline">
        Conoce más sobre nosotros
        <span class="material-symbols-outlined">arrow_forward</span>
      </a>
    </div>
  </div>
</section>
