---
const whatsappUrl = 'https://wa.me/56920092455';
---

<a
  href={whatsappUrl}
  target="_blank"
  rel="noopener"
  aria-label="Contactar por WhatsApp"
  class="fab fixed bottom-6 right-6 md:bottom-8 md:right-8 z-40 block"
>
  <span
    aria-hidden="true"
    class="absolute inset-0 rounded-full bg-whatsapp opacity-40 animate-pulse"
  ></span>
  <span
    class="fab-bubble relative flex items-center justify-center w-14 h-14 rounded-full bg-whatsapp text-white"
    style="box-shadow: 0 10px 28px rgba(37, 211, 102, 0.45), 0 2px 6px rgba(0, 0, 0, 0.1);"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 175.216 175.138"
      width="30"
      height="30"
      fill="currentColor"
      aria-hidden="true"
    >
      <path
        d="M87.431 0C39.222 0 .248 38.974.248 87.184c0 15.41 4.027 30.443 11.682 43.74L0 175.137l45.182-11.844c12.564 6.852 26.7 10.462 41.45 10.462h.006c48.215-.003 87.187-38.98 87.187-87.187 0-23.31-9.075-45.218-25.55-61.696C131.857 13.395 109.948 4.83 86.638 4.83c-.002 0-.002 0 0 0zm0 15.286c-39.733 0-72.07 32.337-72.07 72.072 0 14.572 4.357 28.62 12.612 40.6l-8.29 32.945 33.764-8.86c11.59 6.342 24.6 9.682 37.99 9.682 39.732 0 72.07-32.337 72.07-72.072 0-19.246-7.498-37.342-21.108-50.964C124.79 22.79 106.69 15.285 86.63 15.285h-.2z"
      />
      <path
        fill="#ffffff"
        d="M118.005 95.31c-.273-.114-1.617-.798-1.866-.89-.249-.092-.431-.137-.61.137-.197.297-.767.966-.94 1.164-.173.198-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479c0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"
      />
    </svg>
  </span>
</a>

<style>
  /* Continuous pulse ring around the FAB */
  @keyframes fab-pulse {
    0% {
      transform: scale(1);
      opacity: 0.4;
    }
    80%,
    100% {
      transform: scale(1.45);
      opacity: 0;
    }
  }
  .fab > span:first-child {
    animation: fab-pulse 2s ease-out infinite;
  }
  .fab:hover > span:first-child {
    animation-play-state: paused;
  }

  /* One-shot entrance: fade + scale-up, 1s on page load */
  @keyframes fab-enter {
    from {
      opacity: 0;
      transform: scale(0.4) translateY(20px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }
  .fab-bubble {
    animation: fab-enter 1s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  /* Respect users who prefer reduced motion: snap to final state, no animation */
  @media (prefers-reduced-motion: reduce) {
    .fab > span:first-child,
    .fab-bubble {
      animation: none;
    }
  }
</style>
