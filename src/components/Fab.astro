---
const whatsappUrl = 'https://wa.me/56920092455';
---

<a
  href={whatsappUrl}
  target="_blank"
  rel="noopener"
  aria-label="Contactar por WhatsApp"
  class="fab fixed bottom-6 right-6 md:bottom-8 md:right-8 z-40 block"
>
  <span
    aria-hidden="true"
    class="absolute inset-0 rounded-full bg-whatsapp opacity-40 animate-pulse"
  ></span>
  <span
    class="fab-bubble relative flex items-center justify-center w-14 h-14 rounded-full bg-whatsapp text-white ring-2 ring-white"
    style="box-shadow: 0 10px 28px rgba(37, 211, 102, 0.45), 0 2px 6px rgba(0, 0, 0, 0.1);"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      width="28"
      height="28"
      fill="currentColor"
      aria-hidden="true"
      shape-rendering="geometricPrecision"
    >
      <path
        d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448L.057 24zm6.597-3.51c1.595.948 3.555 1.46 5.535 1.463 5.344 0 9.692-4.347 9.694-9.693A9.616 9.616 0 0 0 14.96 6.195 9.61 9.61 0 0 0 6.105 7.4c-2.628 2.625-3.564 6.18-2.514 9.71l1.573-1.36c-.65-2.34.16-4.85 1.83-6.42a6.473 6.473 0 0 1 5.86-1.493c2.21.498 4.062 1.97 5.118 3.96.475.886.737 1.86.737 2.851 0 .84-.16 1.668-.49 2.46-.776 1.85-2.46 3.27-4.43 3.5-.86.106-1.71.018-2.5-.262l-.13-.04 1.59-4.65-.002-.006zm5.51-7.122c-.066-.112-.244-.18-.518-.31-.273-.13-1.617-.798-1.866-.89-.249-.092-.43-.137-.61.137-.18.273-.697.89-.854 1.074-.157.18-.314.205-.587.07-.273-.137-1.155-.426-2.2-1.358a8.276 8.276 0 0 1-1.527-1.69c-.16-.272-.017-.42.12-.55.124-.122.273-.318.41-.477.137-.158.182-.273.273-.453.092-.18.046-.336-.046-.466-.092-.13-.61-1.473-.836-2.02-.22-.53-.444-.46-.61-.468-.158-.008-.34-.01-.52-.01s-.48.07-.732.336c-.252.27-.96.94-.96 2.29 0 1.328.985 2.61 1.122 2.79.137.18 1.94 2.962 4.7 4.151.658.283 1.171.452 1.57.578.658.21 1.258.18 1.732.11.527-.08 1.617-.66 1.846-1.302.227-.64.227-1.19.16-1.302-.068-.112-.247-.18-.52-.318z"
      />
    </svg>
  </span>
</a>

<style>
  /* Continuous pulse ring around the FAB */
  @keyframes fab-pulse {
    0% {
      transform: scale(1);
      opacity: 0.4;
    }
    80%,
    100% {
      transform: scale(1.45);
      opacity: 0;
    }
  }
  .fab > span:first-child {
    animation: fab-pulse 2s ease-out infinite;
  }
  .fab:hover > span:first-child {
    animation-play-state: paused;
  }

  /* One-shot entrance: fade + scale-up, 1s on page load */
  @keyframes fab-enter {
    from {
      opacity: 0;
      transform: scale(0.4) translateY(20px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }
  .fab-bubble {
    animation: fab-enter 1s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  /* Respect users who prefer reduced motion: snap to final state, no animation */
  @media (prefers-reduced-motion: reduce) {
    .fab > span:first-child,
    .fab-bubble {
      animation: none;
    }
  }
</style>


