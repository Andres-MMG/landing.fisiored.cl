# FisioRed — environment variables
# Copy this file to .env and fill in real values.
# .env is git-ignored.

# SMTP server (Hostinger).
# Default: smtp.hostinger.com (if SMTP_HOST is unset).
SMTP_HOST=smtp.hostinger.com
# Default: 465 (SSL). Use 587 with TLS if SSL is blocked.
SMTP_PORT=465

# Sending account — must be a real email created in Hostinger hPanel
# (Correos > Cuentas de correo).
SMTP_USER=contacto@fisiored.cl

# Password for that email account (the one you set when creating the
# mailbox in hPanel, or its current password if changed).
SMTP_PASS=your-password-here

# Destination inbox where the form messages land.
# Defaults to contacto@fisiored.cl if unset.
MAIL_TO=contacto@fisiored.cl
