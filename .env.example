# FisioRed — environment variables
# Copy this file to .env and fill in real values.
# .env is git-ignored.

# Gmail address that SENDS the mail (the authenticated SMTP account).
# Must be the same address used to generate the App Password below.
SMTP_USER=contacto@fisiored.cl

# Google App Password (NOT your regular account password).
# Generate at https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled on the Google account.
# 16 characters, displayed as 4 groups of 4.
SMTP_PASS=xxxx xxxx xxxx xxxx

# Destination inbox where the form messages land.
# Defaults to contacto@fisiored.cl if unset.
MAIL_TO=contacto@fisiored.cl
